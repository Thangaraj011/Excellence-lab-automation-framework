{
  "name": "playwright-pom-framework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "npx playwright test tests/specs/homepage-Individual-content.spec.js --workers=1",
    "test:ci": "npx playwright test tests/specs/authentication-validation.spec.js",
    "test:fixture": "npx playwright test --grep @fixture2 --workers=1",
    "test:sample": "npx playwright test tests/specs/fixture_based_tests/learningrecords-contents-verification.spec.js",
    "test:report": "playwright test tests/specs/homepage-Individual-content.spec.js && npx allure generate allure-results --clean -o allure-report && npx allure open allure-report",
    "lint": "eslint . --ext .js",
    "format": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/mcp": "^0.0.76",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "allure-commandline": "^2.42.0",
    "allure-playwright": "^3.9.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "playwright": "^1.60.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
